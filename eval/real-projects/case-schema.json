{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Real Project Skill Eval Cases",
  "type": "object",
  "required": [
    "project_id",
    "cases"
  ],
  "properties": {
    "project_id": {
      "type": "string"
    },
    "cases": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
        "skill",
        "kind",
        "size",
        "phase",
        "run_mode",
        "delivery_mode",
        "prompt",
        "expected_artifacts",
        "verification",
        "blocking_questions",
        "rollback_or_compat",
        "expected"
      ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "title": {
            "type": "string"
          },
          "skill": {
            "type": "string",
            "enum": [
              "pathfinder",
              "impact"
            ]
          },
          "kind": {
            "type": "string",
            "enum": [
              "pathfinder",
              "impact-light",
              "impact-full",
              "negative"
            ]
          },
          "scenario_type": {
            "type": "string",
            "enum": [
              "ui-rename",
              "field-rename",
              "permission-add",
              "feature-removal",
              "enum-add",
              "config-migration",
              "non-git-pathfinder",
              "lazy-trap",
              "generic"
            ],
            "description": "标记本 case 属于哪类真实工作场景，用于矩阵覆盖度检查"
          },
          "size": {
            "type": "string",
            "enum": [
              "S",
              "M",
              "L",
              "NEG"
            ]
          },
          "phase": {
            "type": "integer",
            "minimum": 1
          },
          "run_mode": {
            "type": "string",
            "enum": [
              "analysis-only",
              "isolated-copy",
              "non-git-copy"
            ]
          },
          "delivery_mode": {
            "type": "string",
            "enum": [
              "analysis-only",
              "phase4-docs",
              "phase5-delivery",
              "negative-gate",
              "pathfinder-map"
            ]
          },
          "prompt": {
            "type": "string"
          },
          "expected_artifacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "verification": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "blocking_questions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "rollback_or_compat": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "expected": {
            "type": "object",
            "required": [
              "must_cover",
              "must_not_claim",
              "quality_checks"
            ],
            "properties": {
              "must_cover": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "must_not_claim": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "quality_checks": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "allowed_alternatives": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "允许的替代实现方式，判分时不判错"
              }
            }
          },
          "acceptance": {
            "type": "object",
            "description": "Phase 5 交付 case 的标准答案；analysis-only 场景可省略",
            "additionalProperties": false,
            "properties": {
              "expected_changed_files": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              },
              "expected_deleted_files": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                },
                "description": "必须真正删除的文件。用于 feature-removal，防止空壳文件混过 expected_changed_files。"
              },
              "forbidden_changed_files": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              },
              "validators": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              },
              "must_contain": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              },
              "must_not_contain": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              },
              "content_scope": {
                "type": "string",
                "enum": [
                  "expected",
                  "repo"
                ],
                "description": "内容检查范围。默认 expected；feature-removal 等残留扫描用 repo。"
              }
            }
          },
          "review_hints": {
            "type": "object",
            "properties": {
              "likely_files_or_dirs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "risk_topics": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
