# 默认使用哪个生图 Provider（grs / yunwu）
DEFAULT_PROVIDER=yunwu

# 图片比例
# GRS 支持：3:4 / 4:5 / 9:16 等
# Yunwu 支持：1024x1024 / 1536x1024 / 1024x1536
GRS_ASPECT_RATIO=3:4
YUNWU_SIZE=1024x1536
YUNWU_QUALITY=high
YUNWU_THINKING=medium

# ─── Provider: GRS ─────────────────────────────────────────
GRS_API_KEY=sk-c0568dc767f64d168f03335b90c3af12
GRS_API_HOST=https://grsai.dakka.com.cn
GRS_MODEL=gpt-image-2

# ─── Provider: Yunwu ───────────────────────────────────────
YUNWU_API_KEY=sk-vqBCJ7xeJpXtZGSVmMNCur2lVS3eqH2Z0hJlHqLt2NOEurcO
YUNWU_API_HOST=https://yunwu.ai
YUNWU_MODEL=gpt-image-2-all
